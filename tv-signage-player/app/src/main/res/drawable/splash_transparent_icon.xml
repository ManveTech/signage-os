<?xml version="1.0" encoding="utf-8"?>
<!-- Transparent placeholder used as the native system splash screen icon.
     This hides the default Android robot icon so the user sees only the
     dark background (#1C1B1F) before our Compose AppSplashScreen takes over. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <solid android:color="@android:color/transparent" />
    <size
        android:width="1dp"
        android:height="1dp" />
</shape>
